{
  "paths": {
    "tokenizer_path": "../DBs_Randika/trained_assembly_tokenizer/fast_tokenizer",
    "model_path": "./combined_lstm.pt",
    "evaluation_output_dir": "./artifacts/evaluation"
  },
  "device": "cpu",
  "model": {
    "token_embedding_dim": 15,
    "hidden_dim": 330,
    "output_dim": 3,
    "num_layers": 2,
    "dropout": 0.05
  },
  "train": {
    "split": "seen",
    "sequence_length": 200,
    "max_token_length": 15,
    "batch_size": 60,
    "epochs": 10,
    "learning_rate": 0.001,
    "val_ratio": 0.1,
    "split_seed": 42
  },
  "val": {
    "split": "seen",
    "sequence_length": 200,
    "max_token_length": 15,
    "batch_size": 60
  },
  "test": {
    "split": "test",
    "sequence_length": 200,
    "max_token_length": 15,
    "batch_size": 32
  }
}
